# Database
DATABASE_URL=postgres://user:password@localhost:5432/havesmashed

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT EdDSA keys (base64-encoded Ed25519 keypair for signing tokens)
# Generate with: openssl genpkey -algorithm ed25519 -outform DER | base64
JWT_PRIVATE_KEY=base64_encoded_ed25519_private_key
JWT_PUBLIC_KEY=base64_encoded_ed25519_public_key

# JWT expiry in seconds (default: 7 days = 604800)
JWT_EXPIRY=604800

# Admin API key (for /api/admin/* endpoints)
ADMIN_API_KEY=your_random_admin_key_here

# Server
HOST=0.0.0.0
PORT=3000
